# MySQL connection string for the Hostinger database
# e.g. mysql://user:password@localhost:3306/dbname
DATABASE_URL=

# Port to bind to. Hostinger's Node.js app manager sets this automatically;
# only set it manually for local/VPS runs.
PORT=3000

NODE_ENV=production

# Kit (ConvertKit) — used for the email signup forms on the homepage.
# Get the API key from Kit > Settings > Developer.
KIT_API_KEY=
KIT_FORM_ID=9625620

# Legacy/unused — only needed if you reintroduce Manus-hosted auth or storage.
# JWT_SECRET=
# OAUTH_SERVER_URL=
# VITE_OAUTH_PORTAL_URL=
# VITE_APP_ID=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
